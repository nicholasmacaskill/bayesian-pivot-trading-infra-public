# Environment Variables Reference
# Copy this file to .env.local and fill in your own values.
# Never commit .env.local to any repository.

# ── Broker Integration ────────────────────────────────────────────────────────
TL_EMAIL=your_tradelocker_email
TL_PASSWORD=your_tradelocker_password
TL_SERVER=your_server          # e.g. "demo.tradelocker.com"
TL_ACCOUNT_ID=your_account_id

# ── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── Supabase (optional cloud sync) ───────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── AI (local Ollama) ─────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Scanner Parameters ────────────────────────────────────────────────────────
SYMBOLS=BTC/USD,ETH/USD,SOL/USD
TIMEFRAME=5m
HTF_TIMEFRAME=1h
RUN_INTERVAL_MINS=3

# ── Risk Management ───────────────────────────────────────────────────────────
RISK_PER_TRADE=0.007
MAX_DRAWDOWN_LIMIT=0.06
DAILY_DRAWDOWN_LIMIT=0.025
DAILY_TRADE_LIMIT=2
TARGET_RR=3.0
ACTIVE_FIRM=FTMO

# ── AI Conviction Gate ────────────────────────────────────────────────────────
# Set your own threshold — the default is intentionally not published.
AI_THRESHOLD=7.0
AI_THRESHOLD_ASIAN_FADE=6.5
